OPENAI_API_KEY=sk-...
OLLAMA_BASE_URL=http://localhost:11434

# Inference preferences
DEFAULT_PROVIDER=anthropic
CLASSIFICATION_PROVIDER=ollama
STRUCTURE_PROVIDER=anthropic
EXPANSION_PROVIDER=anthropic
